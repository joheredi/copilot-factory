{
  "name": "@factory/application",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Application layer — commands, queries, orchestrators, and use cases.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --build",
    "test": "vitest run --project @factory/application",
    "test:watch": "vitest --project @factory/application",
    "test:coverage": "vitest run --project @factory/application --coverage",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@factory/config": "workspace:*",
    "@factory/domain": "workspace:*",
    "@factory/schemas": "workspace:*",
    "picomatch": "^4.0.3",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/picomatch": "^4.0.2"
  }
}
