{
  "name": "@factory/config",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Configuration layer — hierarchical config resolution, policy loading, and effective snapshot generation.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --build",
    "test": "vitest run --project @factory/config",
    "test:watch": "vitest --project @factory/config",
    "test:coverage": "vitest run --project @factory/config --coverage",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "lint": "eslint .",
    "format": "prettier --write ."
  }
}
