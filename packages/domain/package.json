{
  "name": "@factory/domain",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Domain layer — entities, value objects, enums, invariants, and state machines.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --build",
    "test": "vitest run --project @factory/domain",
    "test:watch": "vitest --project @factory/domain",
    "test:coverage": "vitest run --project @factory/domain --coverage",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "lint": "eslint .",
    "format": "prettier --write ."
  }
}
