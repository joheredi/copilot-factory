{
  "name": "@factory/testing",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Testing utilities — fakes, fixtures, test helpers, and shared test infrastructure.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --build",
    "test": "vitest run --project @factory/testing",
    "test:watch": "vitest --project @factory/testing",
    "test:coverage": "vitest run --project @factory/testing --coverage",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@factory/application": "workspace:*",
    "@factory/domain": "workspace:*",
    "better-sqlite3": "^12.6.2",
    "drizzle-orm": "^0.45.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13"
  }
}
