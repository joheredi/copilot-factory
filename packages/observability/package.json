{
  "name": "@factory/observability",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Observability layer — structured logging, OpenTelemetry tracing, and Prometheus metrics.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc --build",
    "test": "vitest run --project @factory/observability",
    "test:watch": "vitest --project @factory/observability",
    "test:coverage": "vitest run --project @factory/observability --coverage",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  }
}
