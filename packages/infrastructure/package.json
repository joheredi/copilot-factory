{
  "name": "@factory/infrastructure",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Infrastructure layer — database repositories, git services, runner adapters, filesystem storage, event transport.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@factory/application": "workspace:*",
    "@factory/domain": "workspace:*",
    "@factory/schemas": "workspace:*",
    "@github/copilot-sdk": "^0.1.32",
    "zod": "^3.25.76"
  },
  "scripts": {
    "build": "tsc --build",
    "test": "vitest run --project @factory/infrastructure",
    "test:watch": "vitest --project @factory/infrastructure",
    "test:coverage": "vitest run --project @factory/infrastructure --coverage",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "lint": "eslint .",
    "format": "prettier --write ."
  }
}
