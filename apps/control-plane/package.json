{
  "name": "@factory/control-plane",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Backend orchestration service — owns state transitions, scheduling, leases, policies, API, and live events.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --build",
    "test": "vitest run --project @factory/control-plane",
    "test:watch": "vitest --project @factory/control-plane",
    "test:coverage": "vitest run --project @factory/control-plane --coverage",
    "dev": "tsx src/main.ts",
    "start": "node dist/main.js",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "lint": "eslint .",
    "format": "prettier --write .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@factory/application": "workspace:*",
    "@factory/config": "workspace:*",
    "@factory/domain": "workspace:*",
    "@factory/infrastructure": "workspace:*",
    "@factory/observability": "workspace:*",
    "@fastify/static": "^9.0.0",
    "@nestjs/common": "^11.1.16",
    "@nestjs/core": "^11.1.16",
    "@nestjs/platform-fastify": "^11.1.16",
    "@nestjs/platform-socket.io": "^11.1.16",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/websockets": "^11.1.16",
    "better-sqlite3": "^12.6.2",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.8.2",
    "reflect-metadata": "^0.2.2",
    "socket.io": "^4.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@factory/schemas": "workspace:*",
    "@factory/testing": "workspace:*",
    "@nestjs/testing": "^11.1.16",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.4.0",
    "drizzle-kit": "^0.31.9"
  }
}
