{
  "name": "@factory/control-plane",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Backend orchestration service — owns state transitions, scheduling, leases, policies, API, and live events.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --build",
    "test": "vitest run --project @factory/control-plane",
    "test:watch": "vitest --project @factory/control-plane",
    "test:coverage": "vitest run --project @factory/control-plane --coverage",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "lint": "eslint .",
    "format": "prettier --write .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "drizzle-orm": "^0.45.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "drizzle-kit": "^0.31.9"
  }
}
